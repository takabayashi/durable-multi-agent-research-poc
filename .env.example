# Copy to .env and fill in real values. NEVER commit .env.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
# Models (cost-optimized): nano planner, mini investigators (run in parallel), full gpt-5.4 synthesizer.
# Floating aliases track the latest snapshot. Replace with names available to your account.
OPENAI_MODEL_PLANNER=gpt-5.4-nano
OPENAI_MODEL_INVESTIGATOR=gpt-5.4-mini
OPENAI_MODEL_SYNTHESIZER=gpt-5.4
OPENAI_MODEL_COMPACTOR=gpt-5.4-mini   # summarizes older turns when the journal grows (cheap)

# --- Tavily (web_search) ---
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- Research bounds ---
MAX_SUBQUESTIONS=5          # hard cap on planner decomposition breadth
MAX_CONCURRENCY=3           # max investigators running at once (operational guardrail)

# --- Refinement & context journal (Phase 7) ---
FRESHNESS_TTL=3600              # seconds; prior turns older than this drop out of the journal (re-researched)
MAX_JOURNAL_TURNS=3            # recent turns kept verbatim after compaction
CONTEXT_MAX_TOKENS=6000        # est. journal-token budget; over this, older turns are compacted
JOURNAL_MAX_CHARS_PER_TURN=1200 # per-turn truncation when rendering the journal

# --- Tools (Phase 4) ---
WEB_SEARCH_MAX_RESULTS=5    # max Tavily results per web_search call
FETCH_PAGE_MAX_CHARS=6000   # truncate fetched page text to this many characters
MAX_TOOL_TURNS=5            # max investigator LLM<->tool iterations per sub-question
MAX_SOURCES=8               # max sources retained per sub-question

# --- Restate endpoints (local dev defaults) ---
RESTATE_INGRESS_URL=http://localhost:8080
RESTATE_ADMIN_URL=http://localhost:9070
PORT=9080                   # port the service exposes to the Restate server

# --- Durability (Phase 6) ---
OPENAI_TIMEOUT_MS=120000            # per-request OpenAI timeout; bounds one attempt (< inactivity below)
OPENAI_MAX_RETRIES=0                # OpenAI SDK retries; 0 = let Restate's ctx.run own durable retries
RESTATE_INACTIVITY_TIMEOUT_MS=300000 # raise above the longest LLM call so it isn't treated as stuck
RESTATE_ABORT_TIMEOUT_MS=60000      # grace period after inactivity before Restate aborts the attempt

# --- Logging ---
LOG_LEVEL=info
